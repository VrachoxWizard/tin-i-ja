# Supabase
# MCP target project ref: uygdnniouyeqvmysghbu
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google Gemini AI (for valuations and teaser generation) — REQUIRED
GOOGLE_GENERATIVE_AI_API_KEY=your-google-ai-key

# Site URL (used for SEO metadata, OG tags, sitemap, email links)
NEXT_PUBLIC_SITE_URL=https://dealflow.hr

# Resend (transactional email) — REQUIRED
# Get your API key at https://resend.com
RESEND_API_KEY=re_your_api_key

# Email sender — use noreply@resend.dev until your domain is verified in Resend
RESEND_FROM_EMAIL=DealFlow <noreply@resend.dev>

# Admin inbox for contact form submissions
RESEND_ADMIN_EMAIL=admin@dealflow.hr
